---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, site } from '../../data/site.js';

export function getStaticPaths() {
  return projects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      next: projects[(index + 1) % projects.length],
    },
  }));
}

const { project, next } = Astro.props;
const challenges = Array.isArray(project.challenge)
  ? project.challenge
  : [project.challenge];
---

<BaseLayout
  title={`${project.title} — ${site.name}`}
  description={project.overview}
>
  <main class="container">
    <header class="case-hero reveal">
      <div class="case-hero-bg" style={`background-image: url('${project.hero}')`}></div>
      <div class="case-hero-content">
        <div class="case-tags">
          {project.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
        <h1>{project.title}</h1>
        <p class="case-overview">{project.overview}</p>
      </div>
    </header>

    <section class="case-meta reveal">
      <div>
        <div class="k">Role</div>
        <div class="v">{project.role}</div>
      </div>
      <div>
        <div class="k">Year</div>
        <div class="v">{project.year}</div>
      </div>
      <div>
        <div class="k">Focus</div>
        <div class="v">{project.tags.join(' · ')}</div>
      </div>
    </section>

    <section class="case-block">
      <div class="reveal">
        <h2>The challenge</h2>
        {challenges.length > 1 ? (
          <ul class="case-list">
            {challenges.map((c) => <li>{c}</li>)}
          </ul>
        ) : (
          <p>{challenges[0]}</p>
        )}
      </div>
      <div class="reveal" style="--reveal-delay: 100ms">
        <h2>The solution</h2>
        <p>{project.solution}</p>
      </div>
    </section>

    <section class="case-gallery">
      {project.gallery.map((g, i) => (
        <figure class="case-figure reveal" style={`--reveal-delay: ${i * 80}ms`}>
          <img src={g.src} alt={g.caption} loading="lazy" />
          <figcaption>{g.caption}</figcaption>
        </figure>
      ))}
    </section>

    <nav class="case-nav">
      <a class="back-link" href="/#work">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        All projects
      </a>
      <a class="btn btn-ghost" href={`/projects/${next.slug}/`}>
        Next: {next.title}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </nav>
  </main>
</BaseLayout>
