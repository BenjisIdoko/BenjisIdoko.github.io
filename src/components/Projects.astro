---
import { projects } from '../data/site.js';
---

<section class="section" id="work">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Selected work</span>
      <h2 class="section-title">Projects I'm proud of</h2>
      <p class="section-intro">
        A few products where I owned design end-to-end — from research and
        systems to polished, shipped interfaces.
      </p>
    </div>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <article class="project-card reveal" style={`--reveal-delay: ${i * 90}ms`}>
          <a href={`/projects/${p.slug}/`} aria-label={`View ${p.title} case study`}>
            <div class="project-media">
              <span class="project-index">{String(i + 1).padStart(2, '0')}</span>
              <img src={p.cover} alt={`${p.title} preview`} loading="lazy" />
            </div>
            <div class="project-body">
              <h3 class="project-title">
                {p.title}
                <span class="project-arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
                </span>
              </h3>
              <p class="project-desc">{p.summary}</p>
              <div class="tag-row">
                {p.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
